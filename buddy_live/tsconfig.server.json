{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "lib": ["es2017"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["server.ts", "src/specs/**/*.ts", "src/schemas/**/*.ts"],
  "exclude": ["node_modules", "src/lib/**", "src/stores/**"]
}
